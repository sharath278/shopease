<% layout("/layouts/boilerplate") %>

<!-- Hero Section -->

<section class="bg-dark text-white py-5">

    <div class="container text-center">

        <h1 class="display-4 fw-bold">

            Welcome to ShopEase

        </h1>

        <p class="lead mt-3">

            Discover amazing products at unbeatable prices.

        </p>

        <a
            href="/products"
            class="btn btn-warning btn-lg mt-3">

            Shop Now

        </a>

    </div>

</section>

<!-- Features -->

<section class="container py-5">

    <h2 class="text-center mb-5">

        Why ShopEase?

    </h2>

    <div class="row text-center">

        <div class="col-md-3">

            <h1>🚚</h1>

            <h4>Fast Delivery</h4>

            <p>Quick and reliable shipping.</p>

        </div>

        <div class="col-md-3">

            <h1>🔒</h1>

            <h4>Secure Payments</h4>

            <p>Safe and trusted checkout.</p>

        </div>

        <div class="col-md-3">

            <h1>⭐</h1>

            <h4>Top Quality</h4>

            <p>Carefully selected products.</p>

        </div>

        <div class="col-md-3">

            <h1>↩</h1>

            <h4>Easy Returns</h4>

            <p>Hassle-free return policy.</p>

        </div>

    </div>

</section>

<!-- Categories -->

<section class="bg-light py-5">

    <div class="container">

        <h2 class="text-center mb-5">

            Shop by Category

        </h2>

        <div class="row text-center">

            <div class="col-md-3">

                <div class="card shadow-sm">

                    <div class="card-body">

                        <h1>📱</h1>

                        <h5>Electronics</h5>

                    </div>

                </div>

            </div>

            <div class="col-md-3">

                <div class="card shadow-sm">

                    <div class="card-body">

                        <h1>👕</h1>

                        <h5>Fashion</h5>

                    </div>

                </div>

            </div>

            <div class="col-md-3">

                <div class="card shadow-sm">

                    <div class="card-body">

                        <h1>📚</h1>

                        <h5>Books</h5>

                    </div>

                </div>

            </div>

            <div class="col-md-3">

                <div class="card shadow-sm">

                    <div class="card-body">

                        <h1>🏠</h1>

                        <h5>Home</h5>

                    </div>

                </div>

            </div>

        </div>

    </div>

</section>