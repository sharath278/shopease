<% layout("/layouts/boilerplate") %>

<!-- Hero Section -->

<section class="bg-dark text-white py-5">

    <div class="container text-center">

        <h1 class="display-3 fw-bold">
            Welcome to ShopEase
        </h1>

        <p class="lead mt-3">
            Discover the latest products at the best prices.
        </p>

        <a href="/products" class="btn btn-warning btn-lg mt-3">
            Shop Now
        </a>

    </div>

</section>

<!-- Categories -->

<section class="container py-5">

    <h2 class="text-center mb-5">
        Shop by Category
    </h2>

    <div class="row g-4">

        <div class="col-md-3">

            <a href="/products?category=Electronics"
                class="text-decoration-none text-dark">

                <div class="card shadow-sm h-100 text-center">

                    <div class="card-body">

                        <h1>📱</h1>

                        <h4 class="mt-3">
                            Electronics
                        </h4>

                    </div>

                </div>

            </a>

        </div>

        <div class="col-md-3">

            <a href="/products?category=Fashion"
                class="text-decoration-none text-dark">

                <div class="card shadow-sm h-100 text-center">

                    <div class="card-body">

                        <h1>👕</h1>

                        <h4 class="mt-3">
                            Fashion
                        </h4>

                    </div>

                </div>

            </a>

        </div>

        <div class="col-md-3">

            <a href="/products?category=Books"
                class="text-decoration-none text-dark">

                <div class="card shadow-sm h-100 text-center">

                    <div class="card-body">

                        <h1>📚</h1>

                        <h4 class="mt-3">
                            Books
                        </h4>

                    </div>

                </div>

            </a>

        </div>

        <div class="col-md-3">

            <a href="/products?category=Home"
                class="text-decoration-none text-dark">

                <div class="card shadow-sm h-100 text-center">

                    <div class="card-body">

                        <h1>🏠</h1>

                        <h4 class="mt-3">
                            Home
                        </h4>

                    </div>

                </div>

            </a>

        </div>

    </div>

</section>

<!-- Why ShopEase -->

<section class="bg-light py-5">

    <div class="container">

        <h2 class="text-center mb-5">
            Why ShopEase?
        </h2>

        <div class="row text-center">

            <div class="col-md-3">

                <h1>🚚</h1>

                <h4>Fast Delivery</h4>

                <p>
                    Get your products delivered quickly and safely.
                </p>

            </div>

            <div class="col-md-3">

                <h1>🔒</h1>

                <h4>Secure Payments</h4>

                <p>
                    Safe and trusted payment methods.
                </p>

            </div>

            <div class="col-md-3">

                <h1>⭐</h1>

                <h4>Premium Quality</h4>

                <p>
                    Carefully selected products from trusted sellers.
                </p>

            </div>

            <div class="col-md-3">

                <h1>↩</h1>

                <h4>Easy Returns</h4>

                <p>
                    Hassle-free returns and customer support.
                </p>

            </div>

        </div>

    </div>

</section>

<!-- Featured Products -->

<section class="container py-5">

    <div class="text-center">

        <h2>
            Ready to Explore?
        </h2>

        <p class="text-muted mt-3">
            Browse hundreds of products across multiple categories.
        </p>

        <a href="/products" class="btn btn-dark btn-lg mt-2">
            Explore Products
        </a>

    </div>

</section>