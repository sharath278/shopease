<% layout("/layouts/boilerplate") %>

    <div class="container mt-5">

        <h2 class="text-center mb-4">🛒 Your Shopping Cart</h2>

        <% if(!cart || cart.items.length===0){ %>

            <div class="alert alert-info text-center">
                Your cart is empty.
            </div>

            <% } else { %>

                <% let total=0; %>

                    <% for(let item of cart.items){ %>

                        <% total +=item.product.price * item.quantity; %>

                            <div class="card mb-4 shadow-sm cart-card">

                                <div class="row g-0">

                                    <div class="col-md-3">

                                        <img src="<%= item.product.image %>" class="img-fluid cart-image" alt="product">

                                    </div>

                                    <div class="col-md-9">

                                        <div class="card-body">

                                            <h4>
                                                <%= item.product.title %>
                                            </h4>

                                            <p class="text-muted">
                                                <%= item.product.description %>
                                            </p>

                                            <h5 class="text-success">
                                                ₹ <%= item.product.price.toLocaleString("en-IN") %>
                                            </h5>

                                            <!-- Quantity Controls -->
                                            <div class="d-flex align-items-center gap-2 my-3">

                                                <form action="/cart/<%= item.product._id %>/decrease?_method=PATCH"
                                                    method="POST">
                                                    <button class="btn btn-outline-secondary btn-sm">−</button>
                                                </form>

                                                <span class="fw-bold fs-5">
                                                    <%= item.quantity %>
                                                </span>

                                                <form action="/cart/<%= item.product._id %>/increase?_method=PATCH"
                                                    method="POST">
                                                    <button class="btn btn-outline-secondary btn-sm">+</button>
                                                </form>

                                            </div>

                                            <h6>
                                                Subtotal :
                                                ₹ <%= (item.product.price * item.quantity).toLocaleString("en-IN") %>
                                            </h6>

                                            <!-- Remove Button -->
                                            <form action="/cart/<%= item.product._id %>?_method=DELETE" method="POST"
                                                class="mt-3">
                                                <button class="btn btn-outline-danger">
                                                    Remove
                                                </button>
                                            </form>



                                        </div>

                                    </div>

                                </div>

                            </div>

                            <% } %>

                                <div class="card shadow total-card">

                                    <div class="card-body d-flex justify-content-between align-items-center">

                                        <h3>Total</h3>

                                        <h3 class="text-success">
                                            ₹ <%= total.toLocaleString("en-IN") %>
                                        </h3>

                                    </div>
                                </div>


                                <% } %>
                                    <form action="/order" method="post" class="offset-10">
                                        <button type="submit" class="btn btn-primary btn-lg">CheckOut</button>
                                    </form>

    </div>