<% layout("/layouts/boilerplate") %>

<div class="container mt-5">

    <h2 class="text-center mb-5">
        🛠 Admin Panel
    </h2>

    <div class="row g-4">

        <!-- Add Product -->

        <div class="col-md-4">

            <div class="card shadow-sm h-100 text-center">

                <div class="card-body">

                    <h1>📦</h1>

                    <h4 class="mt-3">
                        Add Product
                    </h4>

                    <p class="text-muted">
                        Create and publish a new product.
                    </p>

                    <a
                        href="/products/new"
                        class="btn btn-primary">

                        Add Product

                    </a>

                </div>

            </div>

        </div>

        <!-- Manage Products -->

        <div class="col-md-4">

            <div class="card shadow-sm h-100 text-center">

                <div class="card-body">

                    <h1>🛍</h1>

                    <h4 class="mt-3">
                        Manage Products
                    </h4>

                    <p class="text-muted">
                        View, edit or delete products.
                    </p>

                    <a
                        href="/products"
                        class="btn btn-success">

                        Manage

                    </a>

                </div>

            </div>

        </div>

        <!-- Manage Orders -->

        <div class="col-md-4">

            <div class="card shadow-sm h-100 text-center">

                <div class="card-body">

                    <h1>📋</h1>

                    <h4 class="mt-3">
                        Manage Orders
                    </h4>

                    <p class="text-muted">
                        View customer orders and update status.
                    </p>

                    <a
                        href="/admin/orders"
                        class="btn btn-warning">

                        Orders

                    </a>

                </div>

            </div>

        </div>

    </div>

    <hr class="my-5">

    <div class="row g-4">

        <!-- Coming Soon -->

        <div class="col-md-6">

            <div class="card border-secondary h-100 text-center">

                <div class="card-body">

                    <h1>👥</h1>

                    <h4 class="mt-3">
                        Users
                    </h4>

                    <p class="text-muted">
                        Coming Soon...
                    </p>

                </div>

            </div>

        </div>

        <div class="col-md-6">

            <div class="card border-secondary h-100 text-center">

                <div class="card-body">

                    <h1>📊</h1>

                    <h4 class="mt-3">
                        Analytics
                    </h4>

                    <p class="text-muted">
                        Coming Soon...
                    </p>

                </div>

            </div>

        </div>

    </div>

</div>